{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sbarisic/RaylibGame/schemas/audio-bank.schema.json",
  "title": "Voxelgine audio cue bank",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "cues"],
  "properties": {
    "version": { "const": 1 },
    "cues": {
      "type": "array",
      "items": { "$ref": "#/$defs/cue" }
    }
  },
  "$defs": {
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "gain": { "type": "number", "minimum": 0, "default": 1 },
        "pitchMin": { "type": "number", "exclusiveMinimum": 0, "default": 1 },
        "pitchMax": { "type": "number", "exclusiveMinimum": 0, "default": 1 }
      }
    },
    "cue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "variants"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "variants": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/variant" }
        },
        "bus": {
          "enum": ["Master", "Sfx", "Ambience", "Music", "Voice", "Ui"],
          "default": "Sfx"
        },
        "gain": { "type": "number", "minimum": 0, "default": 1 },
        "spatialMode": {
          "enum": ["TwoDimensional", "ThreeDimensional", "2D", "3D"],
          "default": "ThreeDimensional"
        },
        "minDistance": { "type": "number", "exclusiveMinimum": 0, "default": 1 },
        "maxDistance": { "type": "number", "exclusiveMinimum": 0, "default": 32 },
        "dopplerFactor": { "type": "number", "minimum": 0, "default": 1 },
        "looping": { "type": "boolean", "default": false },
        "streamed": { "type": "boolean", "default": false },
        "maxInstancesPerVariant": { "type": "integer", "minimum": 1, "default": 6 }
      }
    }
  }
}
